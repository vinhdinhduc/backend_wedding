# Database (MySQL)
# Create database first: mysql -u root -e "CREATE DATABASE IF NOT EXISTS tienmung_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
DATABASE_URL=mysql+aiomysql://root:@localhost:3306/tienmung_db

# Then run migrations: alembic upgrade head

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Email (Resend - optional)
RESEND_API_KEY=
FROM_EMAIL=

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173